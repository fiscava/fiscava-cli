{
  "name": "@fiscava/cli",
  "version": "7.21.0",
  "description": "Fiscava CLI — manage personal finances (expenses, income, recurring bills, net worth) from the terminal, and let AI agents (Claude Code, OpenClaw, Cursor) act on your data via scoped tokens.",
  "keywords": [
    "fiscava",
    "cli",
    "personal-finance",
    "expense-tracker",
    "budgeting",
    "net-worth",
    "recurring-payments",
    "finance-api",
    "ai-agent",
    "mcp",
    "openclaw",
    "claude-code",
    "agent-tools"
  ],
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fiscava/fiscava-cli.git"
  },
  "homepage": "https://github.com/fiscava/fiscava-cli#readme",
  "bugs": {
    "url": "https://github.com/fiscava/fiscava-cli/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fiscava": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "type-check:fast": "tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsc/tsconfig.tsbuildinfo",
    "lint": "eslint . --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
